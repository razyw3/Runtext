{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,

    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "isolatedModules": true,

    "jsx": "react-jsx",

    "allowImportingTsExtensions": true,
    "noEmit": true,

    "allowJs": true,

    // 🔥 FIX: lebih aman untuk project Vite
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  }
}